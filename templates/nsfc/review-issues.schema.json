{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NSFC Review Issues",
  "type": "object",
  "required": ["round", "verdict", "overall_score", "issues"],
  "properties": {
    "round": { "type": "integer", "minimum": 1 },
    "verdict": { "type": "string", "enum": ["APPROVED", "NEEDS_WORK"] },
    "overall_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "subscores": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "severity", "section", "location", "problem", "proposed_fix"],
        "properties": {
          "issue_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "section": { "type": "string" },
          "location": { "type": "string" },
          "problem": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "proposed_fix": { "type": "string" },
          "requires_user_decision": { "type": "boolean" }
        }
      }
    }
  }
}

